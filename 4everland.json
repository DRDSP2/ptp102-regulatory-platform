  "name": "ptp102-regulatory-platform",
  "domain": "byrock.eth.limo",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "environmentVariables": {
    "VITE_SUPABASE_URL": "https://vtxrmjuftqtealzymqbk.supabase.co",
    "VITE_SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZ0eHJtanVmdHF0ZWFsenltcWJrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODExNjk4NTMsImV4cCI6MjA5Njc0NTg1M30.dnv8vWedWB6Dk960GLmPoymj0Vi_CApqO81gOO518E8"
  },
  "headers": [
    {
      "source": "/**",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/assets/**",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}